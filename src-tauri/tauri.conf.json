{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "focusforge",
  "version": "0.1.17",
  "identifier": "com.virusescu.focusforge",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Focus Forge",
        "width": 1520,
        "height": 960,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "closable": true,
        "minimizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwMTEwN0FGQkM4QkE4Q0YKUldUUHFJdThyd2NSa0hkTUEzZ2VQa2JzUXIvZUZQbThnODg2cDF1KzBpR09mWUp0V2NWTVRTbS8K",
      "endpoints": [
        "https://raw.githubusercontent.com/virusescu/focusforge/master/update.json"
      ]
    }
  }
}
